AZURE_OPENAI_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/openai/v1/responses
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5

AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-azure-ai-search-key
AZURE_SEARCH_INDEX_NAME=house-rent-index
AZURE_SEARCH_VERIFY_SSL=true

AZURE_STORAGE_CONNECTION_STRING=your-storage-account-connection-string
AZURE_STORAGE_CONTAINER_NAME=house-rent-data
AZURE_STORAGE_BLOB_NAME=house_rent_sample.csv